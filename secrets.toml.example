# Copy this file to .streamlit/secrets.toml and fill in your own values.
# NEVER commit the real secrets.toml to GitHub — it contains a private key.
#
# This file only matters if you want the Google Sheets storage backend
# (needed for deploying on Streamlit Community Cloud, since that
# platform's local filesystem is not persistent). If you only ever run
# the app locally on your own machine, you can ignore this file entirely
# — the app will automatically use local CSV/JSON files instead.
#
# Where each value comes from: after creating a service account and
# downloading its JSON key (see README.md, "Cloud setup" section), every
# field below is copied directly from that JSON file, except
# `spreadsheet`, which is the URL of your own Google Sheet.

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/PASTE_YOUR_SHEET_ID_HERE/edit"
type = "service_account"
project_id = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""
